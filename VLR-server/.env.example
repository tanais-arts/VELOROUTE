# ── VLR-server configuration ──────────────────────────────────────────
# Copier ce fichier en .env et adapter les valeurs

# Port d'écoute
PORT=1666

# Domaine public (utilisé pour les certificats SSL et les URLs)
DOMAIN=hub.studios-voa.com

# Dossier de stockage des fichiers uploadés (chemin absolu recommandé)
# STORAGE_ROOT=/chemin/vers/storage

# Hash bcrypt du mot de passe super-admin (généré par setup_password.js)
SUPER_ADMIN_HASH=

# Login super-admin (défaut : admin)
SUPER_ADMIN_LOGIN=admin

# Origines CORS autorisées (séparées par des virgules, ou * pour tout)
ALLOWED_ORIGINS=https://tanais-arts.github.io

# Chemins des certificats SSL (Let's Encrypt)
# SSL_CERT=/etc/letsencrypt/live/mondomaine.com/fullchain.pem
# SSL_KEY=/etc/letsencrypt/live/mondomaine.com/privkey.pem
